# Copy to .env and fill in your own values. Do not commit .env.
# Backend reads this from nba-tracker-api/.env (see app/config.py).

# Groq API key for AI insights (get from https://console.groq.com/)
GROQ_API_KEY=

# Optional: HTTP proxy for NBA API requests (e.g. Webshare). Leave empty for direct requests.
NBA_API_PROXY=

# Frontend origin for CORS (e.g. https://your-app.vercel.app or http://localhost:5173)
FRONTEND_URL=

# Sentry (optional). Get DSN from sentry.io after creating a FastAPI project.
SENTRY_DSN=
# Set by deploy pipeline; use "local" for local runs.
GIT_SHA=local

# development | production (only development + no FRONTEND_URL allows CORS *)
ENVIRONMENT=development
